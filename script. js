const app = document.getElementById("app");

intro();

function intro(){

app.innerHTML = `
<div class="screen">

<div class="stars"></div>

<h1>A Universe For Geet ❤️</h1>

<p>
Some gifts are wrapped in paper...
<br>
This one was wrapped in stars.
</p>

<br>

<button id="startBtn">
✨ Begin Journey ✨
</button>

</div>
`;

document.getElementById("startBtn").onclick = story;

}

function story(){

app.innerHTML = `
<div class="screen">

<div class="stars"></div>

<h1>Hello Geet ❤️</h1>

<p id="storyText"></p>

<br>

<button
id="continueBtn"
style="display:none;">
Continue ✨
</button>

</div>
`;

const message =
"Some people become family not because of blood... but because of the place they earn in our hearts. Today every star shines a little brighter because it's your special day. Happy 14th Birthday, Geet ❤️";

const text =
document.getElementById("storyText");

let i = 0;

const typing =
setInterval(()=>{

text.innerHTML += message[i];

i++;

if(i >= message.length){

clearInterval(typing);

document
.getElementById("continueBtn")
.style.display = "inline-block";

}

},35);

document
.getElementById("continueBtn")
.onclick = birthday;

}

function birthday(){

app.innerHTML = `
<div class="screen">

<div class="stars"></div>

<h1>🎂 Happy Birthday Geet ❤️</h1>

<p>
Let's decorate your birthday cake.
</p>

<div class="cake">

<div class="plate"></div>

<div class="cake-base"></div>

<div class="cake-middle"></div>

<div class="cake-top"></div>

</div>

<div class="controls">

<button id="c1">🍒 Cherry</button>

<button id="c2">🍫 Chocolate</button>

<button id="c3">✨ Sprinkles</button>

<button id="c4">🌸 Flower</button>

</div>

<div id="decorations"></div>

</div>
`;

setupDecorations();

}

let count = 0;

function setupDecorations(){

const deco =
document.getElementById("decorations");

const map = {

c1:"🍒",

c2:"🍫",

c3:"✨",

c4:"🌸"

};

Object.keys(map).forEach(id=>{

document.getElementById(id).onclick=function(){

deco.innerHTML +=
`<span class="deco">${map[id]}</span>`;

this.disabled = true;

count++;

if(count==4){

setTimeout(showCandles,1200);

}

}

});

}

function showCandles(){

alert("🕯️ 14 Candles coming next!");

} 
